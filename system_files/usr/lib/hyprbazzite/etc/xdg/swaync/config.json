{
    "$schema": "/etc/swaync/configSchema.json",
    "positionX": "right",
    "positionY": "top",
    "layer": "overlay",
    "control-center-layer": "top",
    "control-center-margin-top": 10,
    "control-center-margin-bottom": 10,
    "control-center-margin-right": 10,
    "control-center-margin-left": 10,
    "notification-2fa-action": true,
    "notification-inline-replies": true,
    "notification-window-width": 440,
    "keyboard-shortcuts": true,
    "transition-time": 200,
    "hide-on-clear": false,
    "hide-on-action": true,
    "script-fail-notify": true,
    "scripts": {
        "sound": {
            "exec": "canberra-gtk-play -i message",
            "run-on": "receive"
        }
    },
    "widgets": [
        "buttons-grid",
        "mpris",
        "title",
        "dnd",
        "notifications"
    ],
    "widget-config": {
        "label": {
            "text": "Control Center"
        },
        "title": {
            "text": "Notifications",
            "clear-all-button": true,
            "button-text": "Clear All"
        },
        "dnd": {
            "text": "Do Not Disturb"
        },
        "mpris": {
            "image-size": 96
        },
        "buttons-grid": {
            "actions": [
                {
                    "label": "󰖩",
                    "command": "nm-connection-editor"
                },
                {
                    "label": "󰂯",
                    "command": "blueman-manager"
                },
                {
                    "label": "󰕾",
                    "command": "pavucontrol"
                },
                {
                    "label": "󰍬",
                    "command": "pavucontrol -t 4"
                },
                {
                    "label": "󰏘",
                    "command": "wallpaper-cycle"
                },
                {
                    "label": "󰐥",
                    "command": "/usr/libexec/hyprbazzite-ctl power menu"
                }
            ]
        }
    }
}