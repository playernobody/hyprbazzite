#!/usr/bin/env bash
# wallpaper-cycle - Cycle through GIF wallpapers using swww
#
# This script sets a random GIF wallpaper from the configured directory,
# cycles it at regular intervals, and responds to monitor hotplug events.

set -euo pipefail

# -- Configuration -----------------------------------------------------------
readonly DIR="/usr/share/backgrounds/gif_wallpapers"
readonly TRANSITION_TYPE="grow"
readonly TRANSITION_POS="0.5,0.5"
readonly TRANSITION_FPS=30
readonly TRANSITION_STEP=90
readonly TRANSITION_DURATION=2
readonly CYCLE_INTERVAL=900  # seconds (15 minutes)

# -- Helpers ------------------------------------------------------------------

cycle_now() {
    # Re-scan directory (in case files change)
    if [[ ! -d "$DIR" ]]; then
        return 1
    fi

    local files=("$DIR"/*.gif)
    # Check if directory is not empty
    if [[ ${#files[@]} -eq 0 || ! -e "${files[0]}" ]]; then
        return 1
    fi

    local wallpaper="${files[RANDOM % ${#files[@]}]}"
    if [[ -f "$wallpaper" ]]; then
        swww img \
            --transition-type "$TRANSITION_TYPE" \
            --transition-pos "$TRANSITION_POS" \
            --transition-fps "$TRANSITION_FPS" \
            --transition-step "$TRANSITION_STEP" \
            --transition-duration "$TRANSITION_DURATION" \
            --resize crop \
            --filter Nearest \
            "$wallpaper"
    fi
}

# -- Monitor hotplug listener ------------------------------------------------

monitor_hotplug() {
    udevadm monitor --udev --subsystem-match=drm | \
    while read -r line; do
        if echo "$line" | grep -q 'change'; then
            cycle_now || true
        fi
    done
}

# -- Main ---------------------------------------------------------------------

main() {
    # Trap USR1 signal for manual cycle
    trap cycle_now USR1

    # Initial delay to ensure swww daemon is ready
    sleep 2
    cycle_now || true

    # Start monitor hotplug listener in background
    monitor_hotplug &
    readonly hotplug_pid=$!

    # Cleanup hotplug listener on exit
    trap "kill $hotplug_pid 2>/dev/null" EXIT

    # Infinite loop with interruptible sleep
    while true; do
        sleep "$CYCLE_INTERVAL" &
        wait $!
        cycle_now || true
    done
}

main "$@"
